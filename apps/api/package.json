{
  "name": "@fantasytoken/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -R src/assets dist/assets",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env node_modules/tsx/dist/cli.mjs src/db/seed/run.ts"
  },
  "dependencies": {
    "@fantasytoken/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/websocket": "^11.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "grammy": "^1.42.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.0",
    "satori": "^0.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
