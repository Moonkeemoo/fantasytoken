# Per-app .env files live in apps/api/.env and apps/web/.env.
# This root file is just a manifest of expected variables.

# === apps/api ===
# NODE_ENV=development
# LOG_LEVEL=debug
# PORT=3000
# DATABASE_URL=postgres://fantasytoken:fantasytoken@localhost:5432/fantasytoken
# TELEGRAM_BOT_TOKEN=        # from @BotFather. INV-1 / INV-8: never expose to frontend.
# TON_NETWORK=mainnet

# === apps/web ===
# VITE_API_BASE_URL=http://localhost:3000
# VITE_TONCONNECT_MANIFEST_URL=https://your-domain/tonconnect-manifest.json
