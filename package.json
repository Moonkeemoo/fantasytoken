{
  "name": "fantasytoken",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @fantasytoken/api dev",
    "dev:web": "pnpm --filter @fantasytoken/web dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @fantasytoken/shared build",
    "test": "pnpm build:shared && pnpm -r test",
    "typecheck": "pnpm build:shared && pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix --max-warnings=0"
  }
}
